{
  "hooks": {
    "SessionStart": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "statusMessage": "Checking CLAUDE.md health...",
            "command": "python3 $DOCC_DIR/hooks/docc-health-check.py",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "statusMessage": "Checking for risky commands...",
            "command": "python3 $DOCC_DIR/hooks/docc-danger-guard.py",
            "timeout": 5
          },
          {
            "type": "command",
            "statusMessage": "Validating commit message...",
            "command": "python3 $DOCC_DIR/hooks/docc-commit-guard.py",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "statusMessage": "Monitoring context usage...",
            "command": "python3 $DOCC_DIR/hooks/docc-context-monitor.py",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "statusMessage": "Checking for incomplete tasks...",
            "command": "python3 $DOCC_DIR/hooks/docc-todo-guard.py",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
